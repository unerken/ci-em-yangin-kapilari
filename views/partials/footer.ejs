        const wpButton = document.getElementById('wp-button');
        const wpSelector = document.getElementById('wp-selector');
        const wpClose = document.getElementById('wp-close');

        if(wpButton && wpSelector) {
            const toggleWpMenu = () => {
                wpSelector.classList.toggle('scale-0');
                wpSelector.classList.toggle('opacity-0');
                wpSelector.classList.toggle('pointer-events-none');
            };

            wpButton.addEventListener('click', toggleWpMenu);
            if(wpClose) wpClose.addEventListener('click', toggleWpMenu);

            // Ekranın dışına tıklanınca menüyü kapat
            document.addEventListener('click', (e) => {
                if (!wpButton.contains(e.target) && !wpSelector.contains(e.target)) {
                    wpSelector.classList.add('scale-0', 'opacity-0', 'pointer-events-none');
                }
            });
        }
    });
</script>

