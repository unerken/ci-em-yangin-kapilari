<!-- Özel İmleç (Custom Cursor) HTML -->
<div class="custom-cursor"></div>
<div class="custom-cursor-dot"></div>

<script>
    // Özel İmleç (Custom Cursor) JS Mantığı
    const cursor = document.querySelector('.custom-cursor');
    const cursorDot = document.querySelector('.custom-cursor-dot');

    // İmleci farenin konumuna göre hareket ettir
    document.addEventListener('mousemove', (e) => {
        cursor.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
        cursorDot.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
    });

    // Linkler, butonlar ve özel kartlar üzerinde imleç animasyonu (Hover Efekti)
    const hoverElements = document.querySelectorAll('a, button, .card-charcoal');
    hoverElements.forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    });
</script>