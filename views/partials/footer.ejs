            <!-- Nodex Developer Signature Embed Start (Dark Theme Adapted) -->
            <style>
                /* AYARLAR: Koyu tema (gece siyahı) için açık renk kodları ayarlandı */
                .nodex-signature-container {
                    --nx-main-color: #10b981;       /* Ana Yeşil Renk */
                    --nx-main-rgb: 16, 185, 129;    /* RGB Kodu */
                    --nx-text-color: #f3f4f6;       /* AÇIK RENK: Siyah zemin için beyaz/gri */
                    --nx-label-color: #9ca3af;      /* AÇIK GRİ: "Designed by" yazısı */
                    --nx-font: 'Courier New', Courier, monospace;
                }
            
                /* Stil Kodları */
                .nodex-signature {
                    display: inline-flex;
                    align-items: center;
                    gap: 14px; 
                    text-decoration: none !important;
                    transition: all 0.3s ease;
                    opacity: 0.8; 
                    font-family: var(--nx-font);
                    line-height: 1;
                    cursor: pointer;
                }
            
                .nodex-signature:hover {
                    opacity: 1;
                }
            
                .nodex-label {
                    font-size: 12px; 
                    text-transform: uppercase;
                    letter-spacing: 0.2em;
                    color: var(--nx-label-color);
                    font-weight: 700; 
                }
            
                .nodex-logo-wrapper {
                    display: flex;
                    align-items: center;
                    gap: 10px; 
                }
            
                .nodex-logo-box {
                    display: flex;
                    width: 38px;  
                    height: 38px; 
                    align-items: center;
                    justify-content: center;
                    border-radius: 8px; 
                    border: 1px solid rgba(var(--nx-main-rgb), 0.4);
                    background: rgba(var(--nx-main-rgb), 0.05);
                    color: var(--nx-main-color);
                    font-size: 20px; 
                    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
                }
            
                .nodex-signature:hover .nodex-logo-box {
                    background: var(--nx-main-color);
                    color: #fff;
                    transform: scale(1.1) rotate(5deg);
                    box-shadow: 0 0 20px rgba(var(--nx-main-rgb), 0.4);
                    border-color: var(--nx-main-color);
                }
            
                .nodex-text {
                    font-size: 14px; 
                    font-weight: bold;
                    color: var(--nx-text-color);
                    letter-spacing: -0.02em;
                }
            
                .nodex-highlight {
                    color: var(--nx-main-color);
                    margin-left: 1px;
                }
            
                /* Glitch Animasyonu */
                @keyframes nodex-glitch {
                    0% { transform: translate(0); }
                    20% { transform: translate(-1px, 1px); }
                    40% { transform: translate(-1px, -1px); }
                    60% { transform: translate(1px, 1px); }
                    80% { transform: translate(1px, -1px); }
                    100% { transform: translate(0); }
                }
            
                .nodex-signature:hover .nodex-glitch-char {
                    display: inline-block;
                    animation: nodex-glitch 0.3s infinite;
                }
            </style>
            
            <div class="nodex-signature-container">
                <a href="https://nodexyazilim.com" target="_blank" rel="noopener noreferrer" class="nodex-signature" title="Nodex Yazılım">
                    <span class="nodex-label">Designed by</span>
