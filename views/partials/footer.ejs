<!-- Akıllı Asistan Mantığı (JS) -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const aiButton = document.getElementById('ai-button');
        const aiWindow = document.getElementById('ai-chat-window');
        const aiClose = document.getElementById('ai-close');
        const aiInput = document.getElementById('ai-input');
        const aiSend = document.getElementById('ai-send');
        const aiMessages = document.getElementById('ai-messages');

        // Menü Aç/Kapat
        const toggleAiMenu = () => {
            aiWindow.classList.toggle('scale-0');
            aiWindow.classList.toggle('opacity-0');
            aiWindow.classList.toggle('pointer-events-none');
            if (!aiWindow.classList.contains('opacity-0')) aiInput.focus();
        };

        if(aiButton) aiButton.addEventListener('click', toggleAiMenu);
        if(aiClose) aiClose.addEventListener('click', toggleAiMenu);

        // Ana sayfada 3 saniye sonra otomatik açılma (Sadece 1 kere)
        if (window.location.pathname === '/' && !sessionStorage.getItem('aiAutoOpened')) {
            setTimeout(() => {
                if (aiWindow.classList.contains('opacity-0')) {
                    toggleAiMenu();
                    sessionStorage.setItem('aiAutoOpened', 'true');
                }
            }, 3000);
        }

        // Mesaj Ekleme Fonksiyonu
        const addMessage = (text, isUser = false) => {
            const msgDiv = document.createElement('div');
            msgDiv.className = isUser 
                ? 'bg-brand-red text-white p-3 rounded-2xl rounded-tr-sm self-end max-w-[85%] leading-relaxed'
                : 'bg-white/5 border border-white/10 text-gray-300 p-3 rounded-2xl rounded-tl-sm self-start max-w-[85%] leading-relaxed';
            msgDiv.innerHTML = text;
            aiMessages.appendChild(msgDiv);
            aiMessages.scrollTop = aiMessages.scrollHeight;
        };

        // Gönderme İşlemi
        const handleSend = async () => {
            const text = aiInput.value.trim();
            if(!text) return;
            
            addMessage(text, true); // Kullanıcı mesajını ekle
            aiInput.value = '';
            
            // Simüle edilmiş AI düşünme süresi
            const typingDiv = document.createElement('div');
            typingDiv.className = 'bg-white/5 border border-white/10 text-gray-400 p-3 rounded-2xl rounded-tl-sm self-start max-w-[85%] flex gap-1 items-center';
            typingDiv.innerHTML = '<span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-bounce"></span><span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-bounce" style="animation-delay: 0.1s"></span><span class="w-1.5 h-1.5 bg-gray-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></span>';
            aiMessages.appendChild(typingDiv);
            aiMessages.scrollTop = aiMessages.scrollHeight;

            try {
                // Arka plandaki API'mize (Gemini'ye) soruyu gönderiyoruz
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text })
                });
                const data = await response.json();
                
                aiMessages.removeChild(typingDiv);
                
                // Gemini'den gelen kalın metinleri (**metin**) HTML formatına çevir
                const formattedReply = data.reply.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>');
                addMessage(formattedReply, false);
            } catch (error) {
                aiMessages.removeChild(typingDiv);
                addMessage('⚠️ Bağlantı kurulamadı. Lütfen sorularınız için sağ alttaki WhatsApp butonumuzu kullanın.', false);
            }
        };

        if(aiSend) aiSend.addEventListener('click', handleSend);
        if(aiInput) aiInput.addEventListener('keypress', (e) => {
            if(e.key === 'Enter') handleSend();
        });
    });
</script>

<!-- Özel İmleç (Custom Cursor) HTML -->
<div class="custom-cursor"></div>
<div class="custom-cursor-dot"></div>

<script>
    // Özel İmleç (Custom Cursor) JS Mantığı
    const cursor = document.querySelector('.custom-cursor');
    const cursorDot = document.querySelector('.custom-cursor-dot');

    // İmleci farenin konumuna göre hareket ettir
    document.addEventListener('mousemove', (e) => {
        cursor.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
        cursorDot.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
    });

    // Linkler, butonlar ve özel kartlar üzerinde imleç animasyonu (Hover Efekti)
    const hoverElements = document.querySelectorAll('a, button, .card-charcoal');
    hoverElements.forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    });
</script>