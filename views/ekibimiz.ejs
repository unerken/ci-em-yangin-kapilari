<!DOCTYPE html>
<html lang="tr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="apple-touch-icon" href="/images/favicon.png">

    <!-- SEO Meta Etiketleri -->
    <meta name="description" content="Projeleriniz için her zaman yanınızda olan CI & EM Yangın Kapıları uzman satış ve montaj ekibiyle tanışın.">
    <meta property="og:title" content="Uzman Kadromuz | CI & EM Yangın Kapıları">
    <meta property="og:description" content="Projeleriniz için her zaman yanınızda olan CI & EM Yangın Kapıları uzman satış ve montaj ekibiyle tanışın.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://ciemyanginkapilari.com.tr/images/1.jpg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Uzman Kadromuz | CI & EM Yangın Kapıları">
    <meta name="twitter:description" content="Projeleriniz için her zaman yanınızda olan CI & EM Yangın Kapıları uzman satış ve montaj ekibiyle tanışın.">
    <meta name="twitter:image" content="https://ciemyanginkapilari.com.tr/images/1.jpg">
    <meta property="og:url" content="https://ciemyanginkapilari.com.tr/ekibimiz">
    <link rel="canonical" href="https://ciemyanginkapilari.com.tr/ekibimiz">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <!-- AOS Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- Özel Stil Dosyası -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Tailwind Customization -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'playfair': ['"Playfair Display"', 'serif'],
                        'montserrat': ['"Montserrat"', 'sans-serif']
                    },
                    colors: {
                        'brand-red': '#d32f2f',
                        'night-black': '#0f0f0f',
                        'charcoal-gray': '#1a1a1a'
                    }
                }
            }
        }
    </script>
</head>
<body class="font-montserrat overflow-x-hidden">

    <%- include('partials/header') %>

    <main class="w-full">
        <!-- ==========================================================================
           Hero Section
           ========================================================================== -->
        <section class="relative pt-40 pb-20 md:pt-52 md:pb-32 flex items-center justify-center text-center bg-cover bg-center border-b border-white/5" style="background-image: url('/images/1.jpg');">
            <div class="absolute inset-0 bg-black/80"></div>
            
            <div class="relative z-10 px-4" data-aos="fade-up">
                <span class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-4 block">Gücümüzün Kaynağı</span>
                <h1 class="text-4xl md:text-6xl font-playfair font-bold tracking-tight text-white uppercase mb-6">
                    Uzman <span class="text-brand-red">Ekibimiz</span>
                </h1>
                <p class="max-w-2xl mx-auto text-lg text-gray-400">
                    Başarımızın arkasında, işini tutkuyla yapan ve kaliteyi sizin için bir standart haline getiren profesyonel kadromuz yer almaktadır.
                </p>
            </div>
        </section>

        <!-- ==========================================================================
           Team Layout Section
           ========================================================================== -->
        <section class="py-20 md:py-32 relative" style="background-color: var(--night-black);">
            <div class="max-w-5xl mx-auto px-6 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">
                    
