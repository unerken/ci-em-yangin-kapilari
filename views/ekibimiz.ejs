                        <div class="relative h-96 overflow-hidden">
                            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"></div>
                            <!-- Orhan Oğuz Fotoğrafı -->
                            <img src="/images/orhanoguz.jpeg" alt="CI & EM Yangın Kapıları Montaj Sorumlusu Orhan Oğuz" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
                            <!-- Kart içi alt karartma -->
                            <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-[#1a1a1a] to-transparent z-20"></div>
                        </div>
                        <div class="p-8 relative z-30 -mt-12 text-center">
                            <span class="inline-block bg-gray-700 border border-gray-500 text-white text-[10px] sm:text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest shadow-lg mb-4">Montaj Sorumlusu</span>
                            <h3 class="text-2xl font-playfair font-semibold text-white mb-2">Orhan Oğuz</h3>
                            <p class="text-gray-400 text-sm mb-6 leading-relaxed">Ürettiğimiz premium ve sertifikalı kapıların, şantiye alanında uluslararası standartlara uygun ve kusursuz bir şekilde montajlanmasını sağlar.</p>
                            <a href="https://wa.me/905019433548?text=Merhaba%20Orhan%20Bey,%20web%20sitenizden%20ulaşıyorum." target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-[#25D366]/10 text-[#25D366] border border-[#25D366]/30 rounded-full hover:bg-[#25D366] hover:text-white hover:shadow-[0_0_15px_rgba(37,211,102,0.4)] transition-all duration-300 text-sm font-medium w-max mx-auto">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.323-.297-.124-1.758-.867-2.03-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.099-.297-.124-1.255-.462-2.39-1.305-.88-.739-1.474-1.652-1.647-1.949-.173-.297-.018-.458.13-.582.134-.111.297-.347.446-.52.151-.172.2-.296.3-.495.099-.198.05-.371-.025-.495-.075-.124-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.396-.272.322-1.04 1.014-1.04 2.476 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                                WhatsApp'tan Yazın
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>
</html>