<!DOCTYPE html>
<html lang="tr" class="scroll-smooth overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <!-- SVG Kodlu Dinamik Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%230f0f0f' stroke='%23d32f2f' stroke-width='4'/%3E%3Ctext x='50' y='54' font-family='Georgia, serif' font-size='26' font-weight='bold' text-anchor='middle' dominant-baseline='central' fill='%23ffffff'%3ECİ%3Ctspan fill='%23d32f2f' font-style='italic'%3E%26%3C/tspan%3EEM%3C/text%3E%3C/svg%3E">
    <link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%230f0f0f' stroke='%23d32f2f' stroke-width='4'/%3E%3Ctext x='50' y='54' font-family='Georgia, serif' font-size='26' font-weight='bold' text-anchor='middle' dominant-baseline='central' fill='%23ffffff'%3ECİ%3Ctspan fill='%23d32f2f' font-style='italic'%3E%26%3C/tspan%3EEM%3C/text%3E%3C/svg%3E">

    <!-- SEO Meta Etiketleri -->
    <meta name="description" content="CI & EM Yangın Kapıları'nın İzmir'deki üretim gücü, 25+ yıllık tecrübesi ve uluslararası kalite sertifikaları hakkında detaylı bilgi edinin.">
    <meta name="keywords" content="CI & EM kurumsal, yangın kapısı üreticisi İzmir, çelik kapı fabrikası, yerli üretim yangın kapısı, CE belgeli yangın kapısı, ISO 9001 kapı imalatı">
    <meta name="author" content="CI & EM Yangın Kapıları">
    <meta property="og:title" content="Kurumsal Profil | CI & EM Yangın Kapıları">
    <meta property="og:description" content="Sektördeki köklü tecrübemizle, güvenliği estetikle harmanlıyor, geleceğin mimarisine değer katıyoruz.">
    <meta property="og:url" content="https://ciemyanginkapilari.com.tr/kurumsal">
    <link rel="canonical" href="https://ciemyanginkapilari.com.tr/kurumsal">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <!-- AOS Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <!-- Özel Stil Dosyası -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Tailwind Customization -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'playfair': ['"Playfair Display"', 'serif'],
                        'montserrat': ['"Montserrat"', 'sans-serif']
                    },
                    colors: {
                        'brand-red': '#d32f2f',
                    }
                }
            }
        }
    </script>
</head>
<body class="font-montserrat overflow-x-hidden">

    <%- include('partials/header') %>

    <main class="overflow-x-hidden w-full">
        <!-- ==========================================================================
           Page Hero Section
           ========================================================================== -->
        <section class="relative pt-40 pb-20 md:pt-52 md:pb-32 flex items-center justify-center text-center bg-cover bg-center border-b border-white/5" style="background-image: url('/images/1.jpg');">
            <div class="absolute inset-0 bg-black/80"></div>
            
            <div class="relative z-10 px-4" data-aos="fade-up">
                <span class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-4 block">Hakkımızda</span>
                <h1 class="text-4xl md:text-6xl font-playfair font-bold tracking-tight text-white uppercase mb-6">
                    Kurumsal <span class="text-brand-red">Profil</span>
                </h1>
                <p class="max-w-2xl mx-auto text-lg text-gray-400">
                    Sektördeki köklü tecrübemizle, güvenliği estetikle harmanlıyor, geleceğin mimarisine değer katıyoruz.
                </p>
            </div>
        </section>

        <!-- ==========================================================================
           Hikayemiz (Our Story) Section
           ========================================================================== -->
        <section class="py-20 md:py-32">
            <div class="max-w-7xl mx-auto px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    
                    <!-- Sol: Metin Alanı -->
                    <div data-aos="fade-right">
                        <h2 class="text-3xl md:text-4xl font-playfair font-bold text-white mb-6">Mükemmelliğin <span class="text-brand-red">Mimarisi</span></h2>
                        <div class="h-1 w-20 bg-brand-red mb-8"></div>
                        
                        <p class="text-gray-400 text-lg mb-6 leading-relaxed">
                            CI & EM Yangın Kapıları olarak yola çıktığımız ilk günden bu yana tek bir amaca odaklandık: İnsan hayatını korurken mekanların estetik bütünlüğünden asla taviz vermemek. Yılların getirdiği zanaatkarlık mirasını, günümüzün ileri mühendislik teknolojileriyle birleştiriyoruz.
                        </p>
                        <p class="text-gray-400 text-lg mb-6 leading-relaxed">
                            Uluslararası standartlarda sertifikalandırılmış üretim proseslerimizle; lüks otellerden hastanelere, prestijli konut projelerinden endüstriyel tesislere kadar birçok farklı alanda güvenliğin imzasını atıyoruz.
                        </p>
                        <div class="flex items-center gap-6 mt-10">
                            <div class="text-center">
                                <span class="block text-4xl font-playfair font-bold text-brand-red">25+</span>
                                <span class="text-xs text-gray-500 uppercase tracking-widest">Yıllık Tecrübe</span>
                            </div>
                            <div class="w-px h-12 bg-white/10"></div>
                            <div class="text-center">
                                <span class="block text-4xl font-playfair font-bold text-brand-red">100%</span>
                                <span class="text-xs text-gray-500 uppercase tracking-widest">Yerli Üretim</span>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ: Görsel -->
                    <div class="relative" data-aos="fade-left">
                        <div class="absolute inset-0 bg-brand-red/10 transform translate-x-4 translate-y-4 rounded-2xl z-0"></div>
                        <div class="relative z-10 rounded-2xl overflow-hidden shadow-2xl border border-white/5">
                            <img src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?q=80&w=1000&auto=format&fit=crop" alt="Fabrika ve Üretim Tesisimiz" class="w-full h-[500px] object-cover hover:scale-105 transition-transform duration-700" loading="lazy">
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- ==========================================================================
           Değerlerimiz (Core Values) Section
           ========================================================================== -->
        <section class="py-20 md:py-32 relative border-t border-white/5" style="background-color: var(--charcoal-gray);">
            <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
                    <h2 class="text-3xl md:text-4xl font-playfair font-bold text-white mb-6">Temel <span class="text-brand-red">Değerlerimiz</span></h2>
                    <p class="text-gray-400 text-lg">Bizi biz yapan, üretim bandımızdan çıkan her kapıya işlediğimiz kurum kültürümüz.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
                    <div class="p-8 card-charcoal" data-aos="fade-up" data-aos-delay="100">
                        <div class="flex items-center justify-center h-16 w-16 rounded-full icon-box mx-auto mb-6">
                            <svg class="h-8 w-8 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-playfair font-semibold">Tavizsiz Güvenlik</h3>
                        <p class="mt-4 text-gray-400">İnsan hayatı söz konusu olduğunda toleransımız sıfırdır. Ürünlerimiz en zorlu uluslararası testlerden başarıyla geçmiştir.</p>
                    </div>
                    <div class="p-8 card-charcoal" data-aos="fade-up" data-aos-delay="200">
                        <div class="flex items-center justify-center h-16 w-16 rounded-full icon-box mx-auto mb-6">
                            <svg class="h-8 w-8 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-playfair font-semibold">Sürekli İnovasyon</h3>
                        <p class="mt-4 text-gray-400">Sektördeki gelişmeleri sadece takip etmiyor, Ar-Ge yatırımlarımızla geleceğin kapı teknolojilerine yön veriyoruz.</p>
                    </div>
                    <div class="p-8 card-charcoal" data-aos="fade-up" data-aos-delay="300">
                        <div class="flex items-center justify-center h-16 w-16 rounded-full icon-box mx-auto mb-6">
                            <svg class="h-8 w-8 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-playfair font-semibold">Premium Estetik</h3>
                        <p class="mt-4 text-gray-400">Mimari konseptiniz ne olursa olsun, projenizin prestijini ve görsel bütünlüğünü tamamlayacak özel tasarımlar üretiyoruz.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==========================================================================
           Sertifikalar (Certifications) Section
           ========================================================================== -->
        <section class="py-20 md:py-32 border-t border-white/5" style="background-color: var(--night-black);">
            <div class="max-w-7xl mx-auto px-6 lg:px-8">
                <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
                    <h2 class="text-3xl md:text-4xl font-playfair font-bold text-white mb-6">Kalite ve Güvenlik <span class="text-brand-red">Sertifikaları</span></h2>
                    <p class="text-gray-400 text-lg">Uluslararası normlarda belgelendirilmiş, test edilmiş ve onaylanmış üstün koruma standartları.</p>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                    <!-- Sertifika 1: CE -->
                    <div class="group flex flex-col items-center justify-center p-6 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700 cursor-default" data-aos="zoom-in" data-aos-delay="100">
                        <div class="w-24 h-24 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-red group-hover:shadow-[0_0_25px_rgba(211,47,47,0.4)] transition-all duration-700">
                            <span class="text-3xl font-playfair font-bold text-gray-300 group-hover:text-white transition-colors duration-700">CE</span>
                        </div>
                        <h4 class="text-white font-playfair font-semibold text-lg text-center">CE Belgesi</h4>
                        <p class="text-xs text-gray-500 mt-2 text-center">Avrupa Kalite Standartları</p>
                    </div>

                    <!-- Sertifika 2: ISO 9001 -->
                    <div class="group flex flex-col items-center justify-center p-6 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700 cursor-default" data-aos="zoom-in" data-aos-delay="200">
                        <div class="w-24 h-24 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-red group-hover:shadow-[0_0_25px_rgba(211,47,47,0.4)] transition-all duration-700">
                            <span class="text-2xl font-playfair font-bold text-gray-300 group-hover:text-white transition-colors duration-700">ISO</span>
                        </div>
                        <h4 class="text-white font-playfair font-semibold text-lg text-center">ISO 9001:2015</h4>
                        <p class="text-xs text-gray-500 mt-2 text-center">Kalite Yönetim Sistemi</p>
                    </div>

                    <!-- Sertifika 3: EN 1634-1 -->
                    <div class="group flex flex-col items-center justify-center p-6 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700 cursor-default" data-aos="zoom-in" data-aos-delay="300">
                        <div class="w-24 h-24 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-red group-hover:shadow-[0_0_25px_rgba(211,47,47,0.4)] transition-all duration-700">
                            <span class="text-xl font-playfair font-bold text-gray-300 group-hover:text-white transition-colors duration-700 text-center leading-tight">EN<br>1634-1</span>
                        </div>
                        <h4 class="text-white font-playfair font-semibold text-lg text-center">EN 1634-1</h4>
                        <p class="text-xs text-gray-500 mt-2 text-center">Yangın Dayanım Testi</p>
                    </div>

                    <!-- Sertifika 4: EI 120 -->
                    <div class="group flex flex-col items-center justify-center p-6 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700 cursor-default" data-aos="zoom-in" data-aos-delay="400">
                        <div class="w-24 h-24 rounded-full border border-gray-600 flex items-center justify-center mb-6 group-hover:border-brand-red group-hover:shadow-[0_0_25px_rgba(211,47,47,0.4)] transition-all duration-700">
                             <span class="text-2xl font-playfair font-bold text-gray-300 group-hover:text-white transition-colors duration-700">EI <span class="text-brand-red opacity-0 group-hover:opacity-100 transition-opacity duration-700">120</span></span>
                        </div>
                        <h4 class="text-white font-playfair font-semibold text-lg text-center">EI 120 / 60</h4>
                        <p class="text-xs text-gray-500 mt-2 text-center">Bütünlük ve Yalıtım</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ==========================================================================
           CTA (Call to Action) Section
           ========================================================================== -->
        <section class="py-24 relative overflow-hidden">
            <!-- Arka planda devasa yumuşak kırmızı parlama (Ambient Light) -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-red/10 rounded-full blur-[120px] z-0 pointer-events-none"></div>
    
            <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
                <!-- Yüzen Koyu Renkli Kart -->
                <div class="card-charcoal relative overflow-hidden rounded-3xl p-10 md:p-16 border border-white/5 shadow-2xl" data-aos="fade-up" data-aos-duration="1000">
                    <!-- Kart içi ince kırmızı vurgu çizgisi -->
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-red to-transparent"></div>
    
                    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12">
                        <div class="text-center md:text-left flex-1">
                            <span class="text-brand-red uppercase tracking-widest text-sm font-semibold mb-4 block">Birlikte Çalışalım</span>
                            <h2 class="text-4xl md:text-4xl font-playfair font-bold text-white mb-6 leading-tight">
                                Projeniz İçin <span class="italic font-light text-gray-300">Özel Çözümler</span> Üretelim.
                            </h2>
                            <p class="text-gray-400 text-lg mb-8 max-w-xl mx-auto md:mx-0">
                                Mimari vizyonunuzu ve güvenlik standartlarınızı en üst seviyeye taşıyacak premium kapı sistemleri için uzman ekibimizle iletişime geçin.
                            </p>
                            <!-- Avantaj Detayları -->
                            <div class="flex flex-col sm:flex-row items-center md:items-start justify-center md:justify-start gap-4 sm:gap-8 mb-8 md:mb-0">
                                <div class="flex items-center gap-2 text-sm text-gray-300">
                                    <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    Ücretsiz Keşif
                                </div>
                                <div class="flex items-center gap-2 text-sm text-gray-300">
                                    <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    Özel Üretim
                                </div>
                                <div class="flex items-center gap-2 text-sm text-gray-300">
                                    <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    Uzman Montaj
                                </div>
                            </div>
                        </div>
                        <div class="shrink-0 flex flex-col items-center">
                            <a href="/teklif-al" class="btn-red py-4 px-10 text-lg">
                                Hemen Teklif Al
                            </a>
                            <span class="text-xs text-gray-500 mt-4 block">Formu doldurun, en kısa sürede dönüş yapalım.</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <!-- AOS Animasyon Scripti -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>
</html>