<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans text-gray-900">

    <nav class="bg-gray-900 text-white p-4 shadow-md flex justify-between items-center">
        <h1 class="text-xl font-bold tracking-wider">CI & EM Admin</h1>
        <a href="/admin" class="text-sm text-gray-300 hover:text-white transition-colors">← Panele Dön</a>
    </nav>

    <div class="max-w-3xl mx-auto p-6 mt-8">
        <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-200">
            <h2 class="text-2xl font-semibold text-gray-800 mb-6 border-b pb-4">Yeni Ürün Ekle</h2>
            
            <form action="/admin/urun-ekle" method="POST" class="space-y-6">
                <!-- Ürün Adı & Slug -->
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Ürün Adı</label>
                        <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f] focus:ring-1 focus:ring-[#d32f2f]">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">URL (Slug) <span class="text-xs text-gray-400 font-normal">- Türkçe karakter kullanmayın (Örn: ignis-pro-120)</span></label>
                        <input type="text" name="slug" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f] focus:ring-1 focus:ring-[#d32f2f]">
                    </div>
                </div>

                <!-- Kategori & Görsel -->
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Kategori</label>
                        <select name="category" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f]">
                            <option value="fire">Yangın Kapısı</option>
                            <option value="steel">Çelik Kapı</option>
                            <option value="wood">Ahşap Kapı</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Görsel Yolu</label>
                        <input type="text" name="image" required value="/images/yanginkapi.jpg" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f]">
                    </div>
                </div>

                <!-- Etiketler -->
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Kısa Etiket 1 (Örn: Premium Seri)</label>
                        <input type="text" name="badge1" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f]">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Kısa Etiket 2 (Örn: EI 120 Sertifikalı)</label>
                        <input type="text" name="badge2" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f]">
                    </div>
                </div>

                <!-- Açıklama -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Ürün Açıklaması</label>
                    <textarea name="description" rows="4" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#d32f2f] resize-none"></textarea>
                </div>

                <!-- Butonlar -->
                <div class="flex justify-end gap-4 pt-4 border-t">
                    <a href="/admin" class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">İptal</a>
                    <button type="submit" class="px-6 py-2 bg-[#d32f2f] text-white rounded-lg hover:bg-red-700 shadow transition-colors font-medium">Ürünü Kaydet</button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>